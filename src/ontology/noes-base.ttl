                  obo:IAO_0000119 "https://en.wikipedia.org/wiki/Rowland_ring" ;
                  rdfs:label "thoroidal core setup"@en ;
                  skos:altLabel "Thoroidal core setup is a measuring device of a hysteresis curve of magnetic materials. The specimen shape is a thoroid, around which a magnitization coil is closely wound."@en ,
                                "ring core setup"@en .


