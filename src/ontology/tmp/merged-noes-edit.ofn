AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_22977> "cadmium atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_22977> <http://purl.obolibrary.org/obo/CHEBI_33521>)

