     -->

    


    <!-- https://w3id.org/pmd/noes/NOES_0000001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000142"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0001025"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">TODO: 
which determines the directions in a sheet material in respect to the rolling direction. Rolled sheet direction is a part of material or object.</rdfs:comment>
        <rdfs:label xml:lang="en">rolled sheet direction</rdfs:label>
        <skos:definition xml:lang="en">Rolled sheet direction is a fiat line which is part of rolled material&apos;s intrinsic reference frame.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000002">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000028"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000029"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000030"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">rolled sheet direction value</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition xml:lang="en">Rolled sheet directions is a categorical value specification which specifies the rolled sheet direction. It  includes rolling direction (RD), transverse direction (TD), and normal direction (ND)</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000031 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000094"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000067"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000094"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">longitudinal direction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000033 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000033">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000068"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>TODO: 
1. Refine definition
2. Maybe remove the categorical values</rdfs:comment>
        <rdfs:label xml:lang="en">rolling direction</rdfs:label>
        <skos:definition xml:lang="en">Rolling direction is a rolled sheet direction that is specified by rolling direction (RD).</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000035 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000068"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000033"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">transverse direction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000036 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000036">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000001"/>
        <rdfs:label xml:lang="en">normal direction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000043 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000043">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000857"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">texture parameter Aθ</rdfs:label>
        <rdfs:seeAlso>doi:10.1155/2008/173083</rdfs:seeAlso>
        <skos:definition xml:lang="en">Texture parameter is a intensive quality which quantifies crystallographic texture in materials. Texture parameter is defined as a minimun angle between the magnitization vector and the closest &lt;100&gt; direction in a crystal. Texture parameter can be derived from orientation distribution function (ODF) by integrating ODF f(g) multiplied by Aθ(g) over orientations dg.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000044 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000044">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000857"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">direction averaged texture parameter A</rdfs:label>
        <rdfs:seeAlso>doi:10.1155/2008/173083</rdfs:seeAlso>
        <skos:definition xml:lang="en">Direction averaged texture parameter A is a intensive quality which quantifies crystallographic texture in materials, which are utilized in applications where applied magnetic field is equally distributed in the rolling plane (RP) of the material. Direction averaged texture parameter A is derived from the texture parameter Aθ by integrating Aθ over dθ. For noriented electrical steels it can be simplified as (A0 + 2*A45 + A90) / 4, where A0, A45, and A90 are values of texture parameter Aθ for an applied magnetic field which encloses an angle of 0, 45, and 90 with the rolling direction, respectively.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000045 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000045">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000857"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">texture factor</rdfs:label>
        <skos:definition xml:lang="en">Texture factor is an intensive quality used to quantify texture in materials. It is determined as sum of volume fractions of Goss and Cube texture components divided by the volume fraction of γ-fiber orientations.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000086 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000086">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">α-fibre grain orientation</rdfs:label>
        <skos:altLabel>&lt;110&gt; || RD</skos:altLabel>
        <skos:definition xml:lang="en">α-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;110&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000087 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000087">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:comment xml:lang="en">Note on a crystal structure: 
theoretically possible in both bcc and fcc because &lt;100&gt; are the same types of directions
practically lambda fiber is not stable in fcc because of the slip systems</rdfs:comment>
        <rdfs:label xml:lang="en">λ-fibre grain orientation</rdfs:label>
        <skos:altLabel>&lt;100&gt; || ND</skos:altLabel>
        <skos:definition xml:lang="en">λ-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;100&gt; family of crystallographic directions are oriented parallel to the normal direction (ND) of a sheet material, i,e., normal to the rolling plane.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000088 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000088">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">η-fibre grain orientation</rdfs:label>
        <skos:altLabel>&lt;100&gt; || RD</skos:altLabel>
        <skos:definition xml:lang="en">η-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;100&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000090 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000090">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:comment>NOTE: fcc bs bcc</rdfs:comment>
        <rdfs:label xml:lang="en">cube texture component</rdfs:label>
        <skos:altLabel>{100}&lt;100&gt;</skos:altLabel>
        <skos:definition xml:lang="en">Cube texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;100&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {100} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000091 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000091">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">rotated cube texture component</rdfs:label>
        <skos:altLabel>{100}&lt;110&gt;</skos:altLabel>
        <skos:definition xml:lang="en">Rotated cube texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;110&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {100} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000092 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000092">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">Goss texture component</rdfs:label>
        <skos:altLabel>{110}&lt;100&gt;</skos:altLabel>
        <skos:definition xml:lang="en">Goss texture component is a type of grain orientation which is a quality of some polycrystal, i.e., several grains, oriented in the following way: &lt;100&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {110} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000093 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000093">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">rotated Goss texture component</rdfs:label>
        <skos:altLabel>{110}&lt;110&gt;</skos:altLabel>
        <skos:definition xml:lang="en">Rotated Goss texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;110&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {110} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000094 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000094">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000146"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000068"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">rolling plane</rdfs:label>
        <skos:definition xml:lang="en">Rolling plane is a fiat surface which is a geometric basis of a rolled material. Rolling plane is normal to the normal direction. Rolling plane is a parallel to and has parts rolling, transverse, and longitudinal directions.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000095 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000095">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:label xml:lang="en">γ-fibre grain orientation</rdfs:label>
        <skos:altLabel>&lt;111&gt; || ND</skos:altLabel>
        <skos:definition xml:lang="en">γ-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;111&gt; family of crystallographic directions are oriented parallel to the normal direction (ND) of a sheet material, i.e., normal to the rolling plane.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000161 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000161">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
        <rdfs:comment xml:lang="en">The axiom is not expressible in OWL. 
TODO: write a SWIRL rule</rdfs:comment>
        <rdfs:label xml:lang="en">α*-fibre grain orientation</rdfs:label>
        <skos:altLabel>{h11}&lt;1/h12&gt;</skos:altLabel>
        <skos:definition xml:lang="en">α*-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: {11h} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material and &lt;1/h12&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material.</skos:definition>
    </owl:Class>
    


