                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000057"/>
        <rdfs:subClassOf>
            <owl:Restriction>
