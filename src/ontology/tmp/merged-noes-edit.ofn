AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_18248> "iron atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_18248> <http://purl.obolibrary.org/obo/CHEBI_33521>)

