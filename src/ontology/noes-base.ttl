###  https://w3id.org/pmd/noes/NOES_0000004
noes:NOES_0000004 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000502 ;
                  rdfs:label "plot"@en ;
                  skos:definition "A plot is a 2-D information content entity describing a dependency of one variable on another."@en ;
                  skos:example "B-H curve, stress-strain curve"@en .


###  https://w3id.org/pmd/noes/NOES_0000005
noes:NOES_0000005 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000004 ;
                  rdfs:label "B-H curve"@en ;
                  skos:definition "B-H curve is a plot which describes the dependency of magnetic flux density B on magnetic field strength H in soft and hard magnetic materials."@en .


###  https://w3id.org/pmd/noes/NOES_0000006
noes:NOES_0000006 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000004 ;
                  rdfs:label "stress-strain curve"@en ;
                  skos:definition "Stress-strain curve is a plot which describes the dependency of deformation in a sample on the applied stress (force per unit area)."@en .


###  https://w3id.org/pmd/noes/NOES_0000007
noes:NOES_0000007 rdf:type owl:Class ;
                  rdfs:subClassOf obo:IAO_0000030 ;
                  rdfs:label "3D"@en ;
                  skos:definition "A three-dimensional information content entity is a representation or analysis, commonly applied in studying material properties in its volume or describing a dependency of one variable on two other variables"@en .


###  https://w3id.org/pmd/noes/NOES_0000008
noes:NOES_0000008 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000007 ;
                  rdfs:label "orientation distribution function"@en ;
                  skos:altLabel "ODF"@en ;
                  skos:definition "Orientation distrubution function (ODF) is a 3D information content entity which quantitively describes texture (preferred crystallographic orientation of grains) in polycrystalline materials. ODF can be caclulated from pole figures obtained from the diffraction patterns."@en .


###  https://w3id.org/pmd/noes/NOES_0000009
noes:NOES_0000009 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000834 ;
                  rdfs:label "EBSD map"@en ;
                  skos:definition "EBSD (electron backscatter diffraction) map represents a information content entity which is determined analytically from data obtrained from EBSD characterization. EBSD map provides information about grain size and grain orientation."@en .


