    <!-- https://w3id.org/pmd/noes/NOES_0000094 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000094">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000009"/>
        <rdfs:label xml:lang="en">rolled sheet plane</rdfs:label>
        <skos:definition xml:lang="en">Rolled sheet plane is a two-dimensional spatial region which determines the rolling plane in a rolled material. Rolled sheet plane ction is a part of material or object.</skos:definition>
    </owl:Class>
    


