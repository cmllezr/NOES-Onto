     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://w3id.org/pmd/noes/components/noes-manufacturing.owl">
        <owl:imports rdf:resource="https://w3id.org/pmd/noes/components/noes-shared.owl"/>
    </owl:Ontology>
    


