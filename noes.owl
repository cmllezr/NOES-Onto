        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000885"/>
        <rdfs:label xml:lang="en">incomplete pole figure</rdfs:label>
        <skos:definition xml:lang="en">Incomplete pole figure is a pole figure that lacks intensity data for high tilt angles α.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000077 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000077">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000885"/>
        <rdfs:label xml:lang="en">complete pole figure</rdfs:label>
        <skos:definition xml:lang="en">Complete pole figure is a pole figure which covers the full 0° - 90° range of tilt angles α</skos:definition>
    </owl:Class>
    


