        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000066"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001028"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                                </owl:unionOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000950"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">material reacting process</rdfs:label>
        <skos:definition xml:lang="en">Material reacting process is a process which occurs in a portion of matter due to some of its disposition or behavioral material property which has realization in some  stimulating process. Both the material reacting process and stimulating process must be occurent parts of a planned process, if the planned process takes place.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
        <rdfs:label xml:lang="en">heating</rdfs:label>
        <skos:definition xml:lang="en">Heating is a change of temperature which corresponds to the increase of temperature in the system or object.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
        <rdfs:label xml:lang="en">cooling</rdfs:label>
        <skos:definition xml:lang="en">Cooling is a change of temperature which corresponds to the decrease of temperature in the system or object.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000583"/>
        <rdfs:label xml:lang="en">analytical calculation</rdfs:label>
        <skos:definition xml:lang="en">Analytical calculation is a computing process which has value specification or measurement datum as a specified output. It applies a closed-form mathematical expression or formula to a set it specified inputs (value specifications) without requiring stochastic sampling, iterative numerical solving, or data-driven training.</skos:definition>
    </owl:Class>
    


