    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000553"/>
            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000619"/>
