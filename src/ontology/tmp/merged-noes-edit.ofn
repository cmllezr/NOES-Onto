# Class: <https://w3id.org/pmd/noes/NOES_0000090> (cube texture component)

AnnotationAssertion(rdfs:comment <https://w3id.org/pmd/noes/NOES_0000090> "'preferred crystallographic orientation'
 and ('quality of' some 
    ('grain population'
     and ('part of' some 
        (material
         and ('has geometric basis' some 
            ('rolling direction'
             and ('parallel to' some 
                ('crystallographic direction'
                 and ('denoted by family under cubic symmetry' value '<100>')))))
         and ('has geometric basis' some 
            ('rolling plane'
             and ('parallel to' some 
                ('crystallographic plane'
                 and ('denoted by family under cubic symmetry' value '{100}')))))))
     and ('has quality' some 
        ('crystal structure'
         and (('specified by value' value 'bravais lattice cubic body-centered') or ('specified by value' value 'bravais lattice cubic face-centered'))))))")
AnnotationAssertion(rdfs:comment <https://w3id.org/pmd/noes/NOES_0000090> "NOTE: fcc bs bcc")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/noes/NOES_0000090> "cube texture component"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://w3id.org/pmd/noes/NOES_0000090> "{100}<100>")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/noes/NOES_0000090> "Cube texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: <100> family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {100} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material."@en)
