                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:label xml:lang="en">is_cubic_context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
