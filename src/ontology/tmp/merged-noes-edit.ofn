# Individual: <https://w3id.org/pmd/cryo/CRYO_0000029> (triclinic)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000029> "triclinic"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000029> "Triclinic crystal system is a crystal system with only translational symmetry."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000030> (monoclinic)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000030> "monoclinic"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000030> "Monoclinic crystal system is a crystal system with one twofold rotation axis or one mirror plane."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000031> (orthorhombic)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000031> "orthorhombic"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000031> "Orthorhombic crystal system is a crystal system with three twofold rotation axes or one twofold rotation axis and two mirror planes"@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000032> (tetragonal)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000032> "tetragonal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000032> "Tetragonal crystal system is a crystal system with one fourfold rotation axis."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000033> (rhombohedral)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000033> "rhombohedral"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://w3id.org/pmd/cryo/CRYO_0000033> "trigonal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000033> "Rhombohedral ( trigonal) crystal system is a crystal system with one threefold rotation axis."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000034> (hexagonal)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000034> "hexagonal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000034> "Hexagonal crystal system is a crystal system with one sixfold rotation axis."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000035> (cubic)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000035> "cubic"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000035> "Cubic crystal system is a crystal system with fourfold rotation axes."@en)

