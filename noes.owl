        <rdfs:label xml:lang="it">Newton per Metro Quadrato</rdfs:label>
        <rdfs:label xml:lang="en-us">Newton per Square Meter</rdfs:label>
        <rdfs:label>Newton per Square Metre</rdfs:label>
