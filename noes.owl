        <rdfs:label xml:lang="cs">Newton na Čtvereční Metr</rdfs:label>
        <rdfs:label xml:lang="fr">Newton par Mètre Carré</rdfs:label>
        <rdfs:label xml:lang="ro">Newton pe Metru Pătrat</rdfs:label>
