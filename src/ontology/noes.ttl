###  https://w3id.org/pmd/co/PMD_0040001
co:PMD_0040001 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020132 ;
               rdfs:comment "Length is a size that describes the spacial extend of its bearer in one dimension."@en ;
               rdfs:label "length"@en ;
               skos:altLabel "dimension"@en ;
               skos:definition "Length is a one dimensional size." ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0050000
co:PMD_0050000 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020200 ;
               rdfs:label "bond"@en ;
               skos:definition "A bond is a relational quality describing the force interaction between atoms."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0050002
co:PMD_0050002 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0050000 ;
               obo:IAO_0000119 <https://www.thoughtco.com/metallic-bond-definition-properties-and-examples-4117948> ;
               rdfs:label "metallic bond"@en ;
               skos:definition "A metallic bond is a bond that forms between metal atoms, where electrons are shared in a \"sea\" of electrons that move freely around the metal ions. This type of bonding gives metals their characteristic properties such as conductivity and malleability."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0050051
co:PMD_0050051 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0040001 ;
               obo:IAO_0000119 "“Diameter.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/diameter. Accessed 5 Dec. 2022." ;
               rdfs:label "Durchmesser"@de ,
                          "diameter"@en ;
               rdfs:seeAlso <https://w3id.org/pmd/co/2.0.8/Diameter> ;
               skos:definition "Die Länge einer geraden Linie durch den Mittelpunkt eines Objekts oder Raums."@de ,
                               "The length of a straight line through the center of an object or space."@en .


###  https://w3id.org/pmd/co/PMD_0050153
co:PMD_0050153 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0040001 ;
               rdfs:label "Dicke"@de ,
                          "thickness"@en ;
               rdfs:seeAlso <https://w3id.org/pmd/co/2.0.8/Thickness> ;
               skos:definition "Diese Klasse beschreibt das gemessene Maß in einer Richtung eines Prüfkörpers."@de ,
                               "This class describes the measured dimension in one direction of a test piece."@en .


###  https://w3id.org/pmd/co/PMD_0050154
co:PMD_0050154 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0040001 ;
               rdfs:label "Breite"@de ,
                          "width"@en ;
               rdfs:seeAlso <https://w3id.org/pmd/co/2.0.8/Width> ,
                            <https://www.merriam-webster.com/dictionary/width> ;
               skos:definition "Diese Klasse beschreibt eine horizontale Messung eines Objekts, die im rechten Winkel zur Länge des Objekts vorgenommen wird."@de ,
                               "This class describes a horizontal measurement of an object taken at right angles to the length of the object."@en .


###  https://w3id.org/pmd/co/PMD_0050155
co:PMD_0050155 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020148 ;
               obo:IAO_0000119 "“Shape.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/shape. Accessed 13 Jan. 2023." ;
               rdfs:label "Form"@de ,
                          "shape"@en ;
               skos:definition "Das sichtbare Ausstattungsmerkmal (räumliche Form oder Kontur) eines bestimmten Objektes oder einer Art von Objekt."@de ,
                               "The visible makeup characteristic (spatial form or contour) of a particular item or kind of item.a"@en .


###  https://w3id.org/pmd/co/PMD_0050156
co:PMD_0050156 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0050155 ;
               obo:IAO_0000119 "DIN EN ISO 6892-1:2019" ;
               rdfs:label "Geometrische Form"@de ,
                          "geometry shape"@en ;
               skos:definition "Dieses Konzept beschreibt die geometrischen Abmessungen und das Erscheinungsbild (Form und Abmaße) einer Probe, eines Prüfkörpers oder eines Prüfstücks, wie sie üblicherweise durch eine entsprechende Norm definiert sind. Dementsprechend ist der angegebene Formwert in Übereinstimmung mit der definierenden Norm anzugeben, z. B. \"Zugprüfstück Form 1 gemäß Anhang B der Zugversuchsnorm\"."@de ,
                               "This concept describes the geometric dimensions and appearance (shape and dimensions) of a sample, specimen, or test piece as usually defined by a corresponding standard. Accordingly, the shape value given is in accordance with the defining standard, e.g., ‘tensile test piece shape 1 in accordance with annex B of the tensile test standard’."@en .


###  https://w3id.org/pmd/co/PMD_0050157
co:PMD_0050157 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0050156 ;
               rdfs:label "3D Geometrie"@de ,
                          "shape 3d"@en ;
               skos:definition "A shape 3D is a geometry shape that exists in three dimensions, having length, width, and height, and can be defined by its spatial properties such as volume and surface area."@en ,
                               "Eine 3D Geometrie ist eine geometrische Form, die in drei Dimensionen existiert, mit Länge, Breite und Höhe, und die durch ihre räumlichen Eigenschaften wie Volumen und Oberfläche definiert werden kann."@de ;
               skos:example "Beispiele sind Formen wie Würfel, Kugeln und Pyramiden."@de ,
                            "Examples include shapes like cubes, spheres, and pyramids."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000000
<https://w3id.org/pmd/cryo/CRYO_0000000> rdf:type owl:Class ;
                                         rdfs:subClassOf obo:BFO_0000029 ;
                                         rdfs:label "unit cell"@en ;
                                         skos:definition "Unit cell is a site which is a part of a crystal lattice and represents the smallest volume, from which the lattice can be constructed by translational displacements. Unit cell is characterized by the length of its sides and their angular relations."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000001
<https://w3id.org/pmd/cryo/CRYO_0000001> rdf:type owl:Class ;
                                         rdfs:subClassOf obo:BFO_0000029 ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:BFO_0000051 ;
                                                           owl:someValuesFrom <https://w3id.org/pmd/cryo/CRYO_0000000>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:RO_0001015 ;
                                                           owl:someValuesFrom co:PMD_0020003
                                                         ] ;
                                         rdfs:comment """TODO: 
1. check if located in is meant to be used this way
2. Is there a better alternative to has part?"""@en ;
                                         rdfs:label "crystal lattice"@en ;
                                         skos:definition "Crystal lattice is a site which has unit cell as part and is location of a crystal. It represents a periodic array of points in space, which describe the arrangement of atoms or molecules in a crystal."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000011
<https://w3id.org/pmd/cryo/CRYO_0000011> rdf:type owl:Class ;
                                         rdfs:subClassOf obo:BFO_0000146 ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:BFO_0000050 ;
                                                           owl:someValuesFrom <https://w3id.org/pmd/cryo/CRYO_0000001>
                                                         ] ;
                                         rdfs:label "crystallographic plane"@en ;
                                         skos:definition "Crystallographic plane is a fiat surface which is part of a crystal lattice and which is denoted by Miller indices of a plane."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000012
<https://w3id.org/pmd/cryo/CRYO_0000012> rdf:type owl:Class ;
                                         rdfs:subClassOf obo:BFO_0000142 ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:BFO_0000050 ;
                                                           owl:someValuesFrom <https://w3id.org/pmd/cryo/CRYO_0000001>
                                                         ] ;
                                         rdfs:label "crystallographic direction"@en ;
                                         skos:definition "Crystallographic direction is a fiat line which is part of a crystal lattice and which is denoted by Miller indices of a direction."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000014
<https://w3id.org/pmd/cryo/CRYO_0000014> rdf:type owl:Class ;
                                         rdfs:subClassOf co:PMD_0000501 ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty obo:IAO_0000219 ;
                                                           owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                owl:unionOf ( <https://w3id.org/pmd/cryo/CRYO_0000011>
                                                                                              <https://w3id.org/pmd/cryo/CRYO_0000012>
                                                                                              <https://w3id.org/pmd/cryo/CRYO_0000015>
                                                                                            )
                                                                              ]
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/pmd/cryo/CRYO_0000017> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/pmd/cryo/CRYO_0000018> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://w3id.org/pmd/cryo/CRYO_0000019> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ;
                                         rdfs:comment """TODO 
1. think if its actually 1D..
2. Review the definitions of sublcasses"""@en ;
                                         rdfs:label "Miller indices"@en ;
                                         skos:definition "Miller indices is an information content entity which denotes crystallographic direction, crystallographic plane, or lattice point, i.e., defines their position in respect to the coordinate system of a crystal lattice, and has exactly 3 interger literals, namely h, k. and l."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000015
<https://w3id.org/pmd/cryo/CRYO_0000015> rdf:type owl:Class ;
                                         rdfs:subClassOf obo:BFO_0000147 ,
                                                         [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty obo:BFO_0000050 ;
                                                                                  owl:someValuesFrom [ owl:intersectionOf ( <https://w3id.org/pmd/cryo/CRYO_0000001>
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty obo:RO_0001015 ;
                                                                                                                              owl:someValuesFrom [ owl:intersectionOf ( co:PMD_0020003
                                                                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                                                                          owl:onProperty obo:BFO_0000051 ;
                                                                                                                                                                          owl:someValuesFrom obo:CHEBI_33250
                                                                                                                                                                        ]
                                                                                                                                                                      ) ;
                                                                                                                                                   rdf:type owl:Class
                                                                                                                                                 ]
                                                                                                                            ]
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ]
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty obo:RO_0001015 ;
                                                                                  owl:someValuesFrom obo:CHEBI_33250
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                         rdfs:comment """TODO: 
1. is it relevant for molecules
2. With SHACL it is possible to say that it is the same instance of a atom from the axiom"""@en ;
                                         rdfs:label "lattice point"@en ;
                                         skos:definition "Lattice point is a fiat point which is a part of a lattice and is a location of atoms (or molecules) of a crystal, which is located in the lattice."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000020
<https://w3id.org/pmd/cryo/CRYO_0000020> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/pmd/cryo/CRYO_0000014> ;
                                         rdfs:label "direction Miller indices"@en ;
                                         skos:definition "Direction Miller indices define the components of a sinlge vector in the given direction in a crystal's unit cell. Usually, direction Miller indices are reduced to the lowest set of integers. Direction Miller indices must be written in square brackets, e.g., [hkl]."@en ;
                                         skos:example "[111]" .


###  https://w3id.org/pmd/cryo/CRYO_0000021
<https://w3id.org/pmd/cryo/CRYO_0000021> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/pmd/cryo/CRYO_0000014> ;
                                         rdfs:label "family of directions Miller indices"@en ;
                                         skos:definition "<111>" ,
                                                         "Set of directions Miller indices define the components of symmetrically equivalent directions in a crystal lattice. Set of directions Miller indices must be written as <hkl>."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000022
<https://w3id.org/pmd/cryo/CRYO_0000022> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/pmd/cryo/CRYO_0000014> ;
                                         rdfs:label "plane Miller indices"@en ;
                                         skos:definition """Plane Miller indices define the reciprocals of the fractional intercepts the plane makes with the crystallographic axes, reduced to the lowest set of integers. 
For example, if a plane crosses [100] axis at 1/h, [010 ] axis at 1/k, and [001] axis at 1/l, then such plane is denoted as (hkl) plane. If a plane is parallel to one of the axes, then the corresponding Miller index is 0.
Plane Miller indices must be written in round brackets, e.g., (hkl)."""@en ;
                                         skos:example "(hkl)" .


###  https://w3id.org/pmd/cryo/CRYO_0000023
<https://w3id.org/pmd/cryo/CRYO_0000023> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/pmd/cryo/CRYO_0000014> ;
                                         rdfs:label "family of planes Miller indices"@en ;
                                         skos:definition "Set of planes Miller indices define set of symmetrically equivalent planes. Set of planes must be written in curly brackets, e.g., {hkl}."@en ;
                                         skos:example "{111}" .


###  https://w3id.org/pmd/cryo/CRYO_0000024
<https://w3id.org/pmd/cryo/CRYO_0000024> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/pmd/cryo/CRYO_0000014> ;
                                         rdfs:label "point Miller indices"@en ;
                                         skos:definition "Point Miller indices define the coordinates of a point within a unit cell of a crystal. Point Miller indices must be given in round brackets separated by commas, e.g., (h, k, l)."@en ;
                                         skos:example "(1,1,1)" .


###  https://w3id.org/pmd/noes/NOES_0000000
noes:NOES_0000000 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000026 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:BFO_0000050 ;
                                    owl:someValuesFrom [ rdf:type owl:Class ;
                                                         owl:unionOf ( co:PMD_0020003
                                                                       co:PMD_0020106
                                                                     )
                                                       ]
                                  ] ;
                  rdfs:comment "TODO: refine the axiom to the object aggregates grains"@en ;
                  rdfs:label "crystallographic direction"@en ;
                  skos:definition "Crystallographic direction is a vector within a crystal unit cell, which passes through the origin of crystal reference frame and a specified point in the unit cell. Crystallographic direction is a part of crystal or grain."@en ;
                  skos:example "[110] direction in a cubic unit cell, <110> family of directions in a cubic unit cell"@en .


###  https://w3id.org/pmd/noes/NOES_0000001
noes:NOES_0000001 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000026 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:BFO_0000050 ;
                                    owl:someValuesFrom [ rdf:type owl:Class ;
                                                         owl:unionOf ( co:PMD_0000000
                                                                       [ owl:intersectionOf ( obo:BFO_0000030
                                                                                              [ rdf:type owl:Class ;
                                                                                                owl:complementOf co:PMD_0020003
                                                                                              ]
                                                                                              [ rdf:type owl:Class ;
                                                                                                owl:complementOf co:PMD_0020113
                                                                                              ]
                                                                                            ) ;
                                                                         rdf:type owl:Class
                                                                       ]
                                                                     )
                                                       ]
                                  ] ;
                  rdfs:comment "TODO: add device to the exception"@en ;
                  rdfs:label "rolled sheet direction"@en ;
                  skos:definition "Rolled sheet direction is a one-dimensional spatial region which determines the directions in a sheet material in respect to the rolling direction. Rolled sheet direction is a part of material or object."@en .


###  https://w3id.org/pmd/noes/NOES_0000002
noes:NOES_0000002 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Class ;
                                        owl:oneOf ( noes:NOES_0000028
                                                    noes:NOES_0000029
                                                    noes:NOES_0000030
                                                  )
                                      ] ;
                  rdfs:subClassOf obo:OBI_0001930 ;
                  rdfs:label "rolled sheet directions"@en ;
                  skos:definition "Rolled sheet directions is a categorical value specification which specifies the rolled sheet direction. It  includes rolling direction (RD), transverse direction (TD), and normal direction (ND)"@en .


###  https://w3id.org/pmd/noes/NOES_0000003
noes:NOES_0000003 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0025007 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty co:PMD_0025006 ;
                                    owl:someValuesFrom co:PMD_0000521
                                  ] ;
                  rdfs:label "magnetic field alternating frequency"@en .


###  https://w3id.org/pmd/noes/NOES_0000004
noes:NOES_0000004 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000502 ;
                  rdfs:label "plot"@en ;
                  skos:definition "A plot is a 2-D information content entity describing a dependency of one variable on another."@en ;
                  skos:example "B-H curve, stress-strain curve"@en .


###  https://w3id.org/pmd/noes/NOES_0000005
noes:NOES_0000005 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000004 ;
                  rdfs:label "B-H curve"@en ;
                  skos:definition "B-H curve is a plot which describes the dependency of magnetic flux density B on magnetic field strength H in soft and hard magnetic materials."@en .


###  https://w3id.org/pmd/noes/NOES_0000006
noes:NOES_0000006 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000004 ;
                  rdfs:label "stress-strain curve"@en ;
                  skos:definition "Stress-strain curve is a plot which describes the dependency of deformation in a sample on the applied stress (force per unit area)."@en .


###  https://w3id.org/pmd/noes/NOES_0000007
noes:NOES_0000007 rdf:type owl:Class ;
                  rdfs:subClassOf obo:IAO_0000030 ;
                  rdfs:label "3D"@en ;
                  skos:definition "A three-dimensional information content entity is a representation or analysis, commonly applied in studying material properties in its volume or describing a dependency of one variable on two other variables"@en .


###  https://w3id.org/pmd/noes/NOES_0000008
noes:NOES_0000008 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000007 ;
                  rdfs:label "orientation distribution function"@en ;
                  skos:altLabel "ODF"@en ;
                  skos:definition "Orientation distrubution function (ODF) is a 3D information content entity which quantitively describes texture (preferred crystallographic orientation of grains) in polycrystalline materials. ODF can be caclulated from pole figures obtained from the diffraction patterns."@en .


###  https://w3id.org/pmd/noes/NOES_0000009
noes:NOES_0000009 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000834 ;
                  rdfs:label "EBSD map"@en ;
                  skos:definition "EBSD (electron backscatter diffraction) map represents a information content entity which is determined analytically from data obtrained from EBSD characterization. EBSD map provides information about grain size and grain orientation."@en .


###  https://w3id.org/pmd/noes/NOES_0000010
noes:NOES_0000010 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000829 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom noes:NOES_0000051
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom noes:NOES_0000056
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty co:PMD_0000009 ;
                                    owl:someValuesFrom noes:NOES_0000156
                                  ] ;
                  rdfs:comment """TODO: The definition has to be refined. 
TODO: Write axioms based on the definition"""@en ;
                  rdfs:label "quasi-static (DC) characterization of magnetic properties"@en ;
                  skos:definition "Quasi-static (DC) characterization is a magnetic properties analyzing process for soft magnetic sheet materials which aims to determine a static magnetic curve of the tested material. During the test, the current in the primary winding is changed slowly, thus the frequency of a magnetic field remains low, i.e., below 0.01 Hz. The output of the quasi-static characterization of magnetic properties  is a static B-H curve, which  provides information on hysteresis loss Ph, saturation induction Bsat, coercivity Hc, remanence Br, and maximum permeability µmax. During DC characterization primarily domain wall motion and pinning effects play role."@en ;
                  skos:example "Measurement of hysteresis losses; measurement of saturation magnetic induction at specified maximal magnetic field, e.g., 5000 A/m."@en .


###  https://w3id.org/pmd/noes/NOES_0000011
noes:NOES_0000011 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000829 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom noes:NOES_0000057
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty co:PMD_0000009 ;
                                    owl:someValuesFrom noes:NOES_0000003
                                  ] ;
                  rdfs:comment "Dynamic (AC) characterization of magnetic properties is a magnetic properties analyzing process for soft magnetic sheet materials which aims to determine the total energy loss of a tested material at specific frequency and magnetic flux density. During the test, the current in the primary winding is changed with frequency between 50-400 Hz to ensure sinusoidal waveform of the magnetic flux density at Bpeak. The output of the dynamic characterization of magnetic properties  is a  B-H curve, which  provides information on total core loss Ptot and dynamic permeability µdyn."@en ,
                               """TODO: refine defintion
TODO: write axioms"""@en ;
                  rdfs:label "dynamic (AC) characterization of magnetic properties"@en ;
                  skos:example "Measurement of total power (iron) loss at given current frequency and maximal magnetic induction, e.g. 50 Hz and 1.5 T, or 400 Hz and 1.0 T"@en .


###  https://w3id.org/pmd/noes/NOES_0000012
noes:NOES_0000012 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000829 ;
                  rdfs:label "magnetic property analyzing process using Epstein frame"@en ;
                  skos:definition "Magnetic property analyzing process using Epstein frame is a standardized assay which uses Epstein frame to test magnetic properties of soft magnetic materials, where several (how many) strips are stacked."@en .


###  https://w3id.org/pmd/noes/NOES_0000013
noes:NOES_0000013 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000829 ;
                  rdfs:label "magnetic property analyzing process using single sheet tester"@en ;
                  skos:definition "magnetic property analyzing process using single sheet tester is an assay for determining magnetic properties of soft mangetic materials, where magnetic field H is applied to a single sheet."@en .


###  https://w3id.org/pmd/noes/NOES_0000014
noes:NOES_0000014 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000829 ;
                  rdfs:label "magnetic property analyzing process using thoroidal core"@en ;
                  skos:definition "Magnetic property analyzing process using thoroidal core is an assay for determing magnetic properties of soft magnetic materials, where the sample has closed wound ring core shape. As the ring shape does not have any air gaps or joint losses, this testing procedure provides information on most intrinsic material properties."@en .


###  https://w3id.org/pmd/noes/NOES_0000015
noes:NOES_0000015 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000023 ;
                  rdfs:comment "Cold rolling is a rolling process which aims to reduce thickness of a metallic sheet. Cold rolling takes place at room temperature."@en ;
                  rdfs:label "cold rolling"@en .


###  https://w3id.org/pmd/noes/NOES_0000016
noes:NOES_0000016 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000023 ;
                  rdfs:comment "Hot rolling is a rolling process which aims to reduce the thickness of a sheet material. Hot rolling  takes place at temperatures above alloy's recrystallization temperature."@en ;
                  rdfs:label "hot rolling"@en .


###  https://w3id.org/pmd/noes/NOES_0000017
noes:NOES_0000017 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000015 ;
                  rdfs:comment "Occurence of magnetic flux  is a process that (realizes??) responds with magnetic flux in the material when some magnetic field is applied."@en ;
                  rdfs:label "occurence of magnetic flux"@en .


###  https://w3id.org/pmd/noes/NOES_0000018
noes:NOES_0000018 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000015 ;
                  rdfs:comment """follows  Arrhenius equation.
Has part grain growth and recovery."""@en ;
                  rdfs:label "recrystallization"@en ;
                  skos:definition "Recrystallization is a naturally occuring process which occurs in metallic materials and during which deformed grains are replaced by new defect-free grains. Recrystallization is a thermally activated process, i.e., it requires sufficiently high temperatures for the process to occur. Thus, recrystallization is a process which is part of annealing heat treatment."@en .


###  https://w3id.org/pmd/noes/NOES_0000019
noes:NOES_0000019 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000015 ;
                  rdfs:label "recovery"@en ;
                  skos:definition "Recovery is a naturally occuring process which occurs in metallic materials and during which the reduction of stored deformation energy in grains occurs due to the removal and rearragement of crystal structure defects (dislocations). Recovery is a part of recrystallization process, thus it is a thermally activated process, which occurs during annealing heat treatment."@en .


###  https://w3id.org/pmd/noes/NOES_0000020
noes:NOES_0000020 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000015 ;
                  rdfs:label "grain growth"@en ;
                  skos:definition "Grain growth is a naturally occuring process which occurs in polycrystalline materials. The driving force of grain growth is reduction of the interal energy via reduction of the total grain boundary. Grain growth is a thermally activated process which occurs after recovery and (primary) recrystallization."@en .


###  https://w3id.org/pmd/noes/NOES_0000021
noes:NOES_0000021 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0025009 ;
                  rdfs:label "domain wall motion"@en ;
                  skos:definition "Domain wall motion is a naturally occuring process which occurs in ferromagnetic materials due to the external stimulus such as applied magnetic field."@en .


###  https://w3id.org/pmd/noes/NOES_0000022
noes:NOES_0000022 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0025009 ;
                  rdfs:label "domain wall pinning"@en ;
                  skos:definition "Domain wall pinning is a naturally occuring process which occurs in ferromagnetic materials when domain wall montion is temporally inhibited due to an energy barrier."@en .


###  https://w3id.org/pmd/noes/NOES_0000023
noes:NOES_0000023 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000649 ;
                  rdfs:comment "Rolling is a shaping process in which material is passed through under a roll with the goal of reducing the thickness of a semi-finished object. After rolling the mateiral deformed microstructure, which is characterized by elongated defomed grains, high dislocation density, high internal strains, and preferred grain orientation."@en ;
                  rdfs:label "rolling"@en .


###  https://w3id.org/pmd/noes/NOES_0000024
noes:NOES_0000024 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000906 ;
                  rdfs:comment "The defintion has potential"@en ;
                  rdfs:label "strip-casting"@en ;
                  skos:definition "Strip-casting is a primary shaping from fluid state process for metals and alloys. During Strip-casting the melt flows between two rolls resulting in the strip."@en .


###  https://w3id.org/pmd/noes/NOES_0000025
noes:NOES_0000025 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000650 ;
                  rdfs:label "Schmieden"@de ,
                             "forging"@en ;
                  skos:definition "Forging is a pressure forming process of metals and alloys. During forging the material is heated to forging temperature and formed to the desired form using either hammers and anvils or heat-resistant upper and lower dies."@en .


###  https://w3id.org/pmd/noes/NOES_0000026
noes:NOES_0000026 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000779 ;
                  rdfs:label "normalizing"@en ;
                  skos:definition "Normalizing is a heat treatment process which aims to create uniform grain structure and improve toughness of an alloy. During normalizing the material is heated above its critical temperature, kept at this temperature for a period of time, and then cooled in the air."@en .


###  https://w3id.org/pmd/noes/NOES_0000027
noes:NOES_0000027 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000779 ;
                  rdfs:label "annealing"@en ;
                  skos:definition "Annealing is a heat treatment process which aims to soften an alloy and relieve internal stresses. The material is heated above its critical termperature at which recrystallization occurs. After holding the material at the temperature, it is cooled in a slow and controlled way usually inside an oven."@en .


###  https://w3id.org/pmd/noes/NOES_0000032
noes:NOES_0000032 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000625 ;
                  rdfs:label "scanning electron microscopy"@en ;
                  rdfs:seeAlso "https://www.thermofisher.com/de/de/home/materials-science/learning-center/applications/sem-tem-difference.html" ;
                  skos:altLabel "SEM"@en ;
                  skos:definition "Scanning electron microscopy (SEM) is a type of electron microscopy where a focused beam of electrons scans the surface of an object. An image is created by detecting electrons reflected from the surface. Thus, SEM provides information on the surface and composition of the sample."@en .


###  https://w3id.org/pmd/noes/NOES_0000034
noes:NOES_0000034 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000153 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom co:PMD_0020112
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom noes:NOES_0000042
                                  ] ;
                  rdfs:label "electron backscatter diffraction"@en ;
                  rdfs:seeAlso "Electron Backscatter Diffraction (EBSD) is a SEM based technique for characterizing  material's local microstructure. EBSD provides an information about phases and their distribution in the material, grain structure, grain size, grain boundary, texture  (crystallographic orientation of individual grains), and local strain variation."@en ,
                               "https://www.ebsd.com/ebsd-explained/what-is-ebsd" ;
                  skos:altLabel "EBSD"@en .


###  https://w3id.org/pmd/noes/NOES_0000042
noes:NOES_0000042 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0020148 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0000080 ;
                                    owl:allValuesFrom co:PMD_0000663
                                  ] ;
                  rdfs:label "grain orientation"@en ;
                  skos:definition "Grain orientation is an intensive quality of grains in material's microstructure, which describes the crystal orientation in respect to the external (sample's) reference frame. Grain orientation can be specified by either texture fibers or texture components. When several grains exhibit similar orientations, then the material exhibits a specific crystallographic texture."@en ,
                                  """Grain orientation is an intensive quality of grains in material's microstructure, which describes the crystallographic orientation in respect to the external (sample's) reference frame. Grain orientation can be a quality of an individual grain / crystallite or of a polycrystal, i.e., several grsins with similar crystallographic orientations.
Grain orientation can be specified by either texture fibers or texture components. When several grains exhibit similar orientations, then the material exhibits a specific crystallographic texture."""@en ;
                  skos:example "Cube orientation, λ-fiber orientation"@en .


###  https://w3id.org/pmd/noes/NOES_0000043
noes:NOES_0000043 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000853 ;
                  rdfs:label "texture parameter Aθ"@en ;
                  rdfs:seeAlso "doi:10.1155/2008/173083" ;
                  skos:definition "Texture parameter is a intensive quality which quantifies crystallographic texture in materials. Texture parameter is defined as a minimun angle between the magnitization vector and the closest <100> direction in a crystal. Texture parameter can be derived from orientation distribution function (ODF) by integrating ODF f(g) multiplied by Aθ(g) over orientations dg."@en .


###  https://w3id.org/pmd/noes/NOES_0000044
noes:NOES_0000044 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000853 ;
                  rdfs:label "direction averaged texture parameter A"@en ;
                  rdfs:seeAlso "doi:10.1155/2008/173083" ;
                  skos:definition "Direction averaged texture parameter A is a intensive quality which quantifies crystallographic texture in materials, which are utilized in applications where applied magnetic field is equally distributed in the rolling plane (RP) of the material. Direction averaged texture parameter A is derived from the texture parameter Aθ by integrating Aθ over dθ. For noriented electrical steels it can be simplified as (A0 + 2*A45 + A90) / 4, where A0, A45, and A90 are values of texture parameter Aθ for an applied magnetic field which encloses an angle of 0, 45, and 90 with the rolling direction, respectively."@en .


###  https://w3id.org/pmd/noes/NOES_0000045
noes:NOES_0000045 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000853 ;
                  rdfs:label "texture factor"@en ;
                  skos:definition "Texture factor is an intensive quality used to quantify texture in materials. It is determined as sum of volume fractions of Goss and Cube texture components divided by the volume fraction of γ-fiber orientations."@en .


###  https://w3id.org/pmd/noes/NOES_0000046
noes:NOES_0000046 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000625 ;
                  rdfs:label "transmission electron microscopy"@en ;
                  rdfs:seeAlso "https://www.thermofisher.com/de/de/home/materials-science/learning-center/applications/sem-tem-difference.html" ;
                  skos:altLabel "TEM"@en ;
                  skos:definition "Transmission electron microscopy (TEM) is a type of electron microscopy where a beam of electrons goes through a sample. An image is created by detecting electrons transmitted through the sample. Thus, TEM provides information on the crystal structure, morphology and stress state of the sample"@en .


###  https://w3id.org/pmd/noes/NOES_0000047
noes:NOES_0000047 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000552 ;
                  rdfs:label "electron probe microanalysis"@en ;
                  skos:altLabel "EPMA"@en ;
                  skos:definition "Electron probe microanalysis (EPMA) is a technique to non-destructively determine the chemical element composition of small volumes of solid materials. In EPMA an electron beam is focued on a single point of a surface of a sample. The energy of an electron beam is high enough for electrons to pentrate deeper in the sample causing excitation of characteristic x-rays. An x-ray spectrometer detects those characteristic x-rays providing information about materials chemical composition."@en .


###  https://w3id.org/pmd/noes/NOES_0000048
noes:NOES_0000048 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000825 ;
                  rdfs:comment "A low H_c​ is desirable for soft magnetic materials like electrical steel, indicating easy magnetization and demagnetization"@en ;
                  rdfs:label "coercivity"@en ;
                  skos:altLabel "coercive field strength"@en ;
                  skos:definition "Coercivity is a magnetic property which is stimulated under an application of magnetic field. It describesthe value of the magnetic field strength H required to reduce the Magnetic Flux Density B back to zero after the material has been driven to the saturation of magnetic flux density B_sat."@en ;
                  co:symbol "Hc"@en .


###  https://w3id.org/pmd/noes/NOES_0000049
noes:NOES_0000049 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000825 ;
                  rdfs:label "magnetic induction"@en ;
                  skos:altLabel "magnetic flux density"@en ;
                  skos:definition "Magnetic induction is a magnetic property stimulated by an applied extermal magnetic field H. It characterizes the response of magnetic domains within a material to the applied magnetic field, i.e., the alignment of the magnetic domains and the stregnth of an induced magnetic field in the material."@en ;
                  co:symbol "B" .


###  https://w3id.org/pmd/noes/NOES_0000050
noes:NOES_0000050 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000049 ;
                  rdfs:label "remanence"@en ;
                  skos:altLabel "remnant Induction"@en ;
                  skos:definition "Remanence is the magnetic induction B that remains in the material when the magnetic field strength H is reduced to zero."@en ;
                  co:symbol "Br"@en .


###  https://w3id.org/pmd/noes/NOES_0000051
noes:NOES_0000051 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000049 ;
                  rdfs:label "saturation induction"@en ;
                  skos:altLabel "saturation magnetic flux density"@en ;
                  skos:definition "Saturation induction is a magnetic property which is stimulated under an application of magnetic field. It characterizes the maximum induction B a material can achieve, i.e., the saturation induction is reached when it remains unchanged with increasing magnetic field strength H."@en ;
                  co:symbol "Bsat"@en .


###  https://w3id.org/pmd/noes/NOES_0000052
noes:NOES_0000052 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000825 ;
                  rdfs:label "magnetic permeability"@en ;
                  skos:definition "Magnetic permeability is a magnetic property that measures ability of a material to support the formation of a magnetic field within itself, and can be determined as the ratio between magnetic flux density / induction B and applied magnetic field strength H (μ=B/H)."@en .


###  https://w3id.org/pmd/noes/NOES_0000053
noes:NOES_0000053 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000825 ;
                  rdfs:label "magnetic power loss"@en .


###  https://w3id.org/pmd/noes/NOES_0000054
noes:NOES_0000054 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000053 ;
                  rdfs:label "anomalous loss"@en .


###  https://w3id.org/pmd/noes/NOES_0000055
noes:NOES_0000055 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000053 ;
                  rdfs:label "eddy current Loss"@en .


###  https://w3id.org/pmd/noes/NOES_0000056
noes:NOES_0000056 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000053 ;
                  rdfs:label "hysteresis loss"@en ;
                  co:symbol "Phys"@en .


###  https://w3id.org/pmd/noes/NOES_0000057
noes:NOES_0000057 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000053 ;
                  rdfs:label "total magnetic power loss"@en ;
                  co:symbol "Ptot"@en .


###  https://w3id.org/pmd/noes/NOES_0000058
noes:NOES_0000058 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000621 ;
                  rdfs:label "electrical resistivity"@en ;
                  skos:definition "The electrical resistivity is an electrical property describing the ability of a material to oppose the flow of electric current. It is reciprocal to electric conductivity."@en .


###  https://w3id.org/pmd/noes/NOES_0000059
noes:NOES_0000059 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:comment "Derivative dB/dH"@en ;
                  rdfs:label "differential permeability"@en ;
                  skos:definition "Differential permeability is the instantaneous slope of the magnetization curve or hysteresis loop at any given point"@en ;
                  co:symbol "µd"@en .


###  https://w3id.org/pmd/noes/NOES_0000060
noes:NOES_0000060 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:label "incremental permeability"@en .


###  https://w3id.org/pmd/noes/NOES_0000061
noes:NOES_0000061 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:comment "How easily the material magnetizes from rest"@en ;
                  rdfs:label "initial permeability"@en ;
                  skos:definition "Initial permeability characterizes the slope of the tangent to the magnetization curve at the origin, i.e., H=0 and B=0. It represents the permeability in the weakest magnetic fields"@en ;
                  co:symbol "µi"@en .


###  https://w3id.org/pmd/noes/NOES_0000062
noes:NOES_0000062 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:comment "The maximum value of the normal permeability (the steepest line from the origin to the magnetization curve)."@en ;
                  rdfs:label "maximum permeability"@en ;
                  skos:definition "Maximum permeability is the steepest part of the B-H curve, where the material most readily accepts field. it indicates the easiest magnetization point of the material,"@en ;
                  co:symbol "µmax"@en .


###  https://w3id.org/pmd/noes/NOES_0000063
noes:NOES_0000063 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:comment "A line from the origin to the loop tip"@en ;
                  rdfs:label "normal permeability"@en ;
                  skos:definition "Normal permeabilty is the ratio of the peak magnetic induction B_peak to the peak magnetic field strength H_peak​ for a specific cycle"@en ;
                  co:symbol "μa"@en .


###  https://w3id.org/pmd/noes/NOES_0000064
noes:NOES_0000064 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000052 ;
                  rdfs:label "reversible permeability"@en .


