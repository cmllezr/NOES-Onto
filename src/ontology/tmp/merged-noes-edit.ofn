AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_26833> "sulfur atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_26833> <http://purl.obolibrary.org/obo/CHEBI_25585>)
