        <rdfs:comment>&apos;preferred crystallographic orientation&apos;
 and (&apos;quality of&apos; some 
    (&apos;grain population&apos;
     and (&apos;part of&apos; some 
        (material
         and (&apos;has geometric basis&apos; some 
            (&apos;rolling direction&apos;
             and (&apos;parallel to&apos; some 
                (&apos;crystallographic direction&apos;
                 and (&apos;denoted by family under cubic symmetry&apos; value &apos;&lt;100&gt;&apos;)))))
         and (&apos;has geometric basis&apos; some 
            (&apos;rolling plane&apos;
             and (&apos;parallel to&apos; some 
                (&apos;crystallographic plane&apos;
                 and (&apos;denoted by family under cubic symmetry&apos; value &apos;{100}&apos;)))))))
     and (&apos;has quality&apos; some 
        (&apos;crystal structure&apos;
         and ((&apos;specified by value&apos; value &apos;bravais lattice cubic body-centered&apos;) or (&apos;specified by value&apos; value &apos;bravais lattice cubic face-centered&apos;))))))</rdfs:comment>
        <rdfs:comment>NOTE: fcc bs bcc</rdfs:comment>
        <rdfs:label xml:lang="en">cube texture component</rdfs:label>
        <skos:altLabel>{100}&lt;100&gt;</skos:altLabel>
        <skos:definition xml:lang="en">Cube texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;100&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {100} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material.</skos:definition>
    </owl:Class>
    


