                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnetic power loss at 1.0 T / 400 Hz</rdfs:label>
        <skos:definition xml:lang="en">Magnetic power loss at 1.0 T / 400 Hz is a total magnetic power loss that has been determined at 1.0 T of maximum magnetic induction B and 400 Hz of frequency of alternating magnetic field</skos:definition>
        <co:symbol xml:lang="en">P1.0/400</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000070 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000070">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000521"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnetic field strength</rdfs:label>
        <skos:definition xml:lang="en">Magnetic field strength is a process attribute of an aplication of magnetic field process which characterizes the magnitude the external / applied magnetic field.</skos:definition>
        <co:symbol>H</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000071 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000071">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">magnetic susceptibility</rdfs:label>
        <skos:definition xml:lang="en">Magnetic susceptibility is a disposition of a material which describes how responsive the material is to an applied magnetic field. It is a relation between the induced magnetization M and the magnetic field H.</skos:definition>
        <co:symbol xml:lang="en">χ</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000073 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000073">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025012"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000109"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000008"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000042"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">orientation distribution function calculation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000074 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000074">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000009"/>
        <rdfs:label xml:lang="en">crystallographic plane</rdfs:label>
        <skos:definition xml:lang="en">Crystallographic plane is a an atomic plane within a crystal lattice defined by its orientation relative to the crystal axes. The orientation is specified by the set of Miller indices (hkl) for a single plane, and {hkl} for a set of equivalent planes.</skos:definition>
        <skos:example xml:lang="en">(111) plane, {110} set of planes</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000075 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000075">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000501"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000418"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000042"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000663"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Euler angles</rdfs:label>
        <skos:definition xml:lang="en">In crystallography Euler angles are three angles which describe orientation of a sinlge crystal in respect to the sample&apos;s coordinate system. By aligning coordinate system of every crystal in the sample to the sample&apos;s coordinate system, anisotropy of material&apos;s properties can be investigated.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000076 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000076">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000885"/>
        <rdfs:label xml:lang="en">incomplete pole figure</rdfs:label>
        <skos:definition xml:lang="en">Incomplete pole figure is a pole figure that lacks intensity data for high tilt angles α.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000077 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000077">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000885"/>
        <rdfs:label xml:lang="en">complete pole figure</rdfs:label>
        <skos:definition xml:lang="en">Complete pole figure is a pole figure which covers the full 0° - 90° range of tilt angles α</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000078 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000078">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025999"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">geometric relational quality</rdfs:label>
        <skos:definition xml:lang="en">Geometric relational quality is a relational quality which desribes spatial relation between independent continuants.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000079 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000079">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000075"/>
        <rdfs:label xml:lang="en">Bunge Euler angles</rdfs:label>
        <rdfs:seeAlso>https://mtex-toolbox.github.io/RotationDefinition.html</rdfs:seeAlso>
        <skos:definition xml:lang="en">Bunge Euler angles define the Euler angles according to the Bunge notations, which define the three subsequent rotations about fixed axes, namely ZXZ, i.e., the first rotation is around the z axis, second around the x axis and third again around the z.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000080 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000080">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000501"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000000"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000074"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">TODO: the coordinate of a single atom in the axiom??</rdfs:comment>
        <rdfs:label xml:lang="en">Miller indices</rdfs:label>
        <skos:definition xml:lang="en">In crystallography Miller indices is a notation of lattice planes, directions, and points within a crystal lattice, i.e., in respect to the crystal&apos;s coordinate system.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000081 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000081">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000080"/>
        <rdfs:comment xml:lang="en">TODO: Think what is actually a poinr, does it characterize atom sitting somewhere?</rdfs:comment>
        <rdfs:label xml:lang="en">point Miller indices</rdfs:label>
        <skos:definition xml:lang="en">Point Miller indices define the coordinates of a point within a unit cell of a crystal. Point Miller indices must be given in round brackets separated by commas, e.g., (x, y, z).</skos:definition>
        <skos:example xml:lang="en">(1, 0, 0) point</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000082 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000082">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000080"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000074"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">plane Miller indices</rdfs:label>
        <skos:example xml:lang="en">(110) plane</skos:example>
        <skos:example xml:lang="en">Plane Miller indices define the reciprocals of the fractional intercepts the plane makes with the crystallographic axes, reduced to the lowest set of integers. 
For example, if a plane crosses [100] axis at 1/h, [010 ] axis at 1/k, and [001] axis at 1/l, then such plane is denoted as (hkl) plane. If a plane is parallel to one of the axes, then the corresponding Miller index is 0.
Plane Miller indices must be written in round brackets, e.g., (hkl).</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000083 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000083">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000080"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000074"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">TODO: crystallographic plane specification vs vector specification??</rdfs:comment>
        <rdfs:label xml:lang="en">set of planes Miller indices</rdfs:label>
        <skos:definition xml:lang="en">Set of planes Miller indices define set of symmetrically equivalent planes. Set of planes must be written in curly brackets, e.g., {hkl}.</skos:definition>
        <skos:definition xml:lang="en">{111} set of planes</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000084 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000084">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000080"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">direction Miller indices</rdfs:label>
        <skos:definition xml:lang="en">Direction Miller indices define the components of a sinlge vector in the given direction in a crystal&apos;s unit cell. Usually, direction Miller indices are reduced to the lowest set of integers. direction Miller indices must be written in square brackets, e.g., [uvw].</skos:definition>
        <skos:example xml:lang="en">[111] direction</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000085 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000085">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000080"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">set of directions Miller indices</rdfs:label>
        <skos:definition xml:lang="en">Set of directions Miller indices define the components of symmetrically equivalent directions in a crystal&apos;s unit cell. Set of directions Miller indices must be written as &lt;uvw&gt;.</skos:definition>
        <skos:example xml:lang="en">&lt;110&gt; set of directions</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000086 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000086">
