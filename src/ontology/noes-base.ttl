                                                                     )
                                                       ]
                                  ] ;
                  rdfs:label "magnetic field strength"@en ;
                  skos:definition "Magnetic field strength is a process attribute of an aplication of magnetic field process which characterizes the magnitude the external / applied magnetic field."@en ;
                  co:symbol "H" .


###  https://w3id.org/pmd/noes/NOES_0000071
