                                       rdfs:subClassOf co:PMD_0040001 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Parallele Länge"@de ,
                                                  "parallel length"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/ParallelLength> ;
