        <rdfs:label xml:lang="en">widmanstatten structure</rdfs:label>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020111 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020111">
        <rdfs:label xml:lang="en">martensite</rdfs:label>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020117 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020117">
        <rdfs:label xml:lang="en">aggregate state solid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds between entities transmit shear forces.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020118 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020118">
        <rdfs:label xml:lang="en">aggregate state liquid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds of the entities transmit no shear force.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020119 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020119">
        <rdfs:label xml:lang="en">aggregate state gaseous</rdfs:label>
        <skos:definition xml:lang="en">A state where the entities have no bonding.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020120 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020120">
        <rdfs:label xml:lang="en">aggregate state plasma</rdfs:label>
        <skos:definition xml:lang="en">An aggregate state where the entities are atom nuclei and have no bonds.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020121 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020121">
        <rdfs:label xml:lang="en">aggregate state atom gas</rdfs:label>
        <skos:definition xml:lang="en">A gaseous state where the gas entities are atoms.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020122 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020122">
        <rdfs:label xml:lang="en">aggregate state supercritical fluid</rdfs:label>
        <skos:definition xml:lang="en">A state with strong bindings between entities that do not transmit shear force.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020123 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020123">
        <rdfs:label xml:lang="en">aggregate state mesomorphic</rdfs:label>
        <skos:definition xml:lang="en">A state where some bonds transmit shear stresses and some do not.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020124 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020124">
        <rdfs:label xml:lang="en">aggregate state suprafluid</rdfs:label>
        <skos:definition xml:lang="en">A state with frictionless binding that transmits no shear force between entities.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020125 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020125">
        <rdfs:label xml:lang="en">aggregate state suprasolid</rdfs:label>
        <skos:definition xml:lang="en">A state that exhibits suprafluid and solid properties.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020217 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020217">
        <rdfs:label xml:lang="en">short range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features up to a few entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020218 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020218">
        <rdfs:label xml:lang="en">medium range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of many entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020219 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020219">
        <rdfs:label xml:lang="en">long range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of virtually all entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020242 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020242">
        <rdfs:label xml:lang="en">no range order</rdfs:label>
        <skos:definition xml:lang="en">no periodic arrangement of structural features of entites</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000029 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000029">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000030"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000031"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000032"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000033"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000034"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">triclinic</rdfs:label>
        <skos:definition xml:lang="en">Triclinic crystal system is a crystal system with only translational symmetry.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000030 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000030">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000031"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000032"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000033"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000034"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">monoclinic</rdfs:label>
        <skos:definition xml:lang="en">Monoclinic crystal system is a crystal system with one twofold rotation axis or one mirror plane.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000031 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000031">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000032"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000033"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000034"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">orthorhombic</rdfs:label>
        <skos:definition xml:lang="en">Orthorhombic crystal system is a crystal system with three twofold rotation axes or one twofold rotation axis and two mirror planes</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000032 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000032">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000033"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000034"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">tetragonal</rdfs:label>
        <skos:definition xml:lang="en">Tetragonal crystal system is a crystal system with one fourfold rotation axis.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000033 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000033">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000034"/>
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">rhombohedral</rdfs:label>
        <skos:altLabel xml:lang="en">trigonal</skos:altLabel>
        <skos:definition xml:lang="en">Rhombohedral ( trigonal) crystal system is a crystal system with one threefold rotation axis.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000034 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000034">
        <owl:differentFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
        <rdfs:label xml:lang="en">hexagonal</rdfs:label>
        <skos:definition xml:lang="en">Hexagonal crystal system is a crystal system with one sixfold rotation axis.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000035 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000035">
        <rdfs:label xml:lang="en">cubic</rdfs:label>
        <skos:definition xml:lang="en">Cubic crystal system is a crystal system with fourfold rotation axes.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000040 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000040">
        <rdf:type rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000023"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000125"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000126"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000127"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000128"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000130"/>
        <obo:RO_0002351 rdf:resource="https://w3id.org/pmd/cryo/components/cryo-individuals.owl/CRYO_0000000"/>
        <cryo:CRYO_0000017 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</cryo:CRYO_0000017>
        <cryo:CRYO_0000018 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</cryo:CRYO_0000018>
        <cryo:CRYO_0000019 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</cryo:CRYO_0000019>
        <rdfs:label xml:lang="en">{100}</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000043 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000043">
        <rdfs:label xml:lang="en">primitive</rdfs:label>
        <skos:altLabel>P</skos:altLabel>
        <skos:definition xml:lang="en">Primitive centering type is a centering type, where lattice points are located only on the corners of a unit cell, i.e., at coordinates (0,0,0).</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000044 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000044">
        <rdfs:label xml:lang="en">body centered</rdfs:label>
        <skos:altLabel>I</skos:altLabel>
        <skos:definition xml:lang="en">Body centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of a unit cell, i.e., at coordinates (1/2,1/2,1/2).</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000045 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000045">
        <rdfs:label xml:lang="en">face centered</rdfs:label>
        <skos:altLabel>F</skos:altLabel>
        <skos:definition xml:lang="en">Face centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of each faces of a unit cell, i.e., at coordinates (1/2,1/2,0), (1/2,0,1/2), and (0,1/2,1/2).</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000046 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000046">
        <rdfs:comment>Add symbol annotation property</rdfs:comment>
        <rdfs:label xml:lang="en">base centered</rdfs:label>
        <skos:altLabel>C</skos:altLabel>
        <skos:definition xml:lang="en">Base centered centering type is a centering type, where lattice points are located on the corners of a unit cell, i.e., at coordinates (0,0,0), and one additional lattice point is located at the center of a base of the cell, i.e., at coordinates (1/2,1/2,0).</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000064 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/cryo/CRYO_0000064">
        <rdf:type rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000023"/>
