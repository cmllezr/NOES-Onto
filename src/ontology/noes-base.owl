                                                                    <rdf:Description>
                                                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.27</xsd:minInclusive>
                                                                    </rdf:Description>
                                                                </owl:withRestrictions>
                                                            </rdfs:Datatype>
                                                        </owl:someValuesFrom>
                                                    </owl:Restriction>
