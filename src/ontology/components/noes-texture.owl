                                                                    </owl:Restriction>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                                        <owl:hasValue rdf:resource="https://w3id.org/pmd/noes/NOES_0000028"/>
                                                                    </owl:Restriction>
                                                                </owl:intersectionOf>
                                                            </owl:Class>
                                                        </owl:someValuesFrom>
                                                    </owl:Restriction>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000168"/>
                                                        <owl:hasValue rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000038"/>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000591"/>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                        <owl:hasValue rdf:resource="https://w3id.org/pmd/co/PMD_0020018"/>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000176"/>
        <rdfs:label xml:lang="en">α-fibre grain orientation</rdfs:label>
        <skos:altLabel>&lt;110&gt; || RD</skos:altLabel>
        <skos:definition xml:lang="en">α-fibre grain orientation is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: &lt;110&gt; family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material.</skos:definition>
    </owl:Class>
    


