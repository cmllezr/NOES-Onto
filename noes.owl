    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000010">
        <obo:IAO_0000115>A time unit which is equal to the duration of 9 192 631 770 periods of the radiation corresponding to the transition between the two hyperfine levels of the ground state of the caesium 133 atom.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>s</oboInOwl:hasExactSynonym>
        <rdfs:label>second</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000010"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A time unit which is equal to the duration of 9 192 631 770 periods of the radiation corresponding to the transition between the two hyperfine levels of the ground state of the caesium 133 atom.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>BIPM:BIPM</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000012">
        <obo:IAO_0000115>A thermodynamic temperature unit which is equal to the fraction 1/273.16 of the thermodynamic temperature of the triple point of water.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>K</oboInOwl:hasExactSynonym>
        <rdfs:label>kelvin</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000012"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A thermodynamic temperature unit which is equal to the fraction 1/273.16 of the thermodynamic temperature of the triple point of water.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>BIPM:BIPM</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000016">
        <obo:IAO_0000115>A length unit which is equal to one thousandth of a meter or 10^[-3] m.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>millimetre</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>mm</oboInOwl:hasExactSynonym>
        <rdfs:label>millimeter</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000016"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A length unit which is equal to one thousandth of a meter or 10^[-3] m.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000027">
        <obo:IAO_0000115>A temperature unit which is equal to one kelvin degree. However, they have their zeros at different points. The centigrade scale has its zero at 273.15 K.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>C</oboInOwl:hasExactSynonym>
        <rdfs:label>degree Celsius</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000027"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A temperature unit which is equal to one kelvin degree. However, they have their zeros at different points. The centigrade scale has its zero at 273.15 K.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000031">
        <obo:IAO_0000115>A time unit which is equal to 60 seconds.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>min</oboInOwl:hasExactSynonym>
        <rdfs:label>minute</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000031"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A time unit which is equal to 60 seconds.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000032">
        <obo:IAO_0000115>A time unit which is equal to 3600 seconds or 60 minutes.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>h</oboInOwl:hasExactSynonym>
        <rdfs:label>hour</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000032"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A time unit which is equal to 3600 seconds or 60 minutes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000076">
        <obo:IAO_0000115>A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>(x)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>chi</oboInOwl:hasExactSynonym>
        <rdfs:label>mole fraction</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000076"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000106">
        <obo:IAO_0000115>A frequency unit which is equal to 1 complete cycle of a recurring phenomenon in 1 second.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Hz</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>s^1</oboInOwl:hasExactSynonym>
        <rdfs:label>hertz</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000106"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A frequency unit which is equal to 1 complete cycle of a recurring phenomenon in 1 second.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000110">
        <obo:IAO_0000115>A pressure unit which is equal to the pressure or stress on a surface caused by a force of 1 newton spread over a surface of 1 m^[2].</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Pa</oboInOwl:hasExactSynonym>
        <rdfs:label>pascal</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000110"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A pressure unit which is equal to the pressure or stress on a surface caused by a force of 1 newton spread over a surface of 1 m^[2].</owl:annotatedTarget>
        <oboInOwl:hasDbXref>NIST:NIST</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000163">
        <obo:IAO_0000115>A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>w/w</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>weight-weight percentage</oboInOwl:hasExactSynonym>
        <rdfs:label>mass percentage</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000163"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000164">
        <obo:IAO_0000115>A dimensionless concentration unit which denotes the mass of the substance in a mixture as a percentage of the volume of the entire mixture.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>(w/v)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>weight-volume percentage</oboInOwl:hasExactSynonym>
        <rdfs:label>mass volume percentage</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000164"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dimensionless concentration unit which denotes the mass of the substance in a mixture as a percentage of the volume of the entire mixture.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>UOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000185">
        <obo:IAO_0000115>A plane angle unit which is equal to 1/360 of a full rotation or 1.7453310^[-2] rad.</obo:IAO_0000115>
        <rdfs:label>degree</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000185"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A plane angle unit which is equal to 1/360 of a full rotation or 1.7453310^[-2] rad.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Wikipedia</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UO_0000228">
        <obo:IAO_0000115>A magnetic flux density unit which is equal to one weber per square meter.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>T</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>Wb/m2</oboInOwl:hasExactSynonym>
        <rdfs:label>tesla</rdfs:label>
    </rdf:Description>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UO_0000228"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A magnetic flux density unit which is equal to one weber per square meter.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>WordNet:WordNet</oboInOwl:hasDbXref>
    </owl:Axiom>
    <rdf:Description rdf:about="http://qudt.org/schema/qudt/DerivedUnit">
        <dcterms:description rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML">
  &lt;p&gt;A &lt;em&gt;Derived Unit&lt;/em&gt; is a type specification for units that are derived from other units.
  &lt;/p&gt;</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt"/>
        <rdfs:label>Derived Unit</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020098">
        <NOES_0000122 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</NOES_0000122>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000124">
        <NOES_0000122 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</NOES_0000122>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000143">
        <NOES_0000122 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</NOES_0000122>
    </rdf:Description>
    


    <!-- 
