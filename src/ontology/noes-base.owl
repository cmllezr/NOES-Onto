                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020106"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000000"/>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
                                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000122"/>
                                                    </owl:Restriction>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000067"/>
                                                        <owl:someValuesFrom>
                                                            <owl:Class>
                                                                <owl:intersectionOf rdf:parseType="Collection">
                                                                    <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000001"/>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                                                                        <owl:someValuesFrom>
                                                                            <owl:Class>
                                                                                <owl:intersectionOf rdf:parseType="Collection">
                                                                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                                                                    <owl:Restriction>
                                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                                                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020106"/>
                                                                                    </owl:Restriction>
                                                                                </owl:intersectionOf>
                                                                            </owl:Class>
                                                                        </owl:someValuesFrom>
                                                                    </owl:Restriction>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                                        <owl:hasValue rdf:resource="https://w3id.org/pmd/noes/NOES_0000030"/>
                                                                    </owl:Restriction>
                                                                </owl:intersectionOf>
                                                            </owl:Class>
                                                        </owl:someValuesFrom>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/noes/NOES_0000042"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020106"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000000"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
                                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/noes/NOES_0000122"/>
                                            </owl:Restriction>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000067"/>
                                                <owl:someValuesFrom>
                                                    <owl:Class>
                                                        <owl:intersectionOf rdf:parseType="Collection">
                                                            <rdf:Description rdf:about="https://w3id.org/pmd/noes/NOES_0000001"/>
                                                            <owl:Restriction>
                                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                                                                <owl:someValuesFrom>
                                                                    <owl:Class>
                                                                        <owl:intersectionOf rdf:parseType="Collection">
                                                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                                                            <owl:Restriction>
                                                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                                                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020106"/>
                                                                            </owl:Restriction>
                                                                        </owl:intersectionOf>
                                                                    </owl:Class>
                                                                </owl:someValuesFrom>
                                                            </owl:Restriction>
                                                            <owl:Restriction>
                                                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                                <owl:hasValue rdf:resource="https://w3id.org/pmd/noes/NOES_0000030"/>
                                                            </owl:Restriction>
                                                        </owl:intersectionOf>
                                                    </owl:Class>
                                                </owl:someValuesFrom>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">γ-fibre grain orientation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">frequency</rdfs:label>
        <skos:definition xml:lang="en">frequency is a process attribute which characterizes the rate per second of oscillation or vibration.</skos:definition>
        <skos:example xml:lang="en">Frequency of electromagnetic wave, Frequency of sound wave.</skos:example>
        <co:symbol>f</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000624"/>
        <rdfs:label xml:lang="de">Transmissionselektronenmikroskop</rdfs:label>
        <rdfs:label xml:lang="en">transmission electron microscope</rdfs:label>
        <skos:definition xml:lang="en">A Transmission Electron Microscope (SEM) is a Measuring Device that produces high-resolution images of a sample&apos;s internal structure by transmitting electrons through the sample.</skos:definition>
        <skos:definition xml:lang="de">Ein Transmissionselektronenmikroskop (TEM) ist ein Messgerät, das hochauflösende Bilder der inneren Struktur einer Probe erzeugt, indem es Elektronen durch die Probe strahlt.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0025009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0025009">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
