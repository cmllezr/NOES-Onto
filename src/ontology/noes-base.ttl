                  rdfs:comment """'preferred crystallographic orientation'
 and ('quality of' some 
    ('grain population'
     and ('part of' some 
        (material
         and ('has geometric basis' some 
            ('rolling direction'
             and ('parallel to' some 
                ('crystallographic direction'
                 and ('denoted by family under cubic symmetry' value '<100>')))))
         and ('has geometric basis' some 
            ('rolling plane'
             and ('parallel to' some 
                ('crystallographic plane'
                 and ('denoted by family under cubic symmetry' value '{100}')))))))
     and ('has quality' some 
        ('crystal structure'
         and (('specified by value' value 'bravais lattice cubic body-centered') or ('specified by value' value 'bravais lattice cubic face-centered'))))))""" ,
                               "NOTE: fcc bs bcc" ;
                  rdfs:label "cube texture component"@en ;
                  skos:altLabel "{100}<100>" ;
                  skos:definition "Cube texture component is a type of grain orientation which is quality of polycrystal, i.e., several grains, oriented in the following way: <100> family of crystallographic directions are oriented parallel to the rolling direction (RD) of a sheet material and {100} family of crystallographic planes are oriented parallel to the rolling plane of a sheet material."@en .


