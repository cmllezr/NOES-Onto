    <!-- https://w3id.org/pmd/noes/NOES_0000041 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000041">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/noes/NOES_0000074"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Note that intrinsic reference frame is &quot;grounded into&quot; the material entity, i.e., it moves with it, and if material entity ceases to exist so will its intrinsic reference frame.</rdfs:comment>
        <rdfs:label xml:lang="en">intrinsic reference frame</rdfs:label>
        <skos:definition xml:lang="en">Intrinsic reference frame is an immaterial entity  which is geometric basis of some material entity, e.g., material or an object. Intrinsic reference frame has parts continuant fiat boundaries, e.g., specific directions or planes which uniquely define this reference frame.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/noes/NOES_0000042 -->

    <owl:Class rdf:about="https://w3id.org/pmd/noes/NOES_0000042">
        <owl:equivalentClass>
