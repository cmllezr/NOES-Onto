co:PMD_0020119 rdf:type owl:NamedIndividual ;
               rdfs:label "aggregate state gaseous"@en ;
               skos:definition "A state where the entities have no bonding."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


