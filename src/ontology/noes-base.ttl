                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty co:PMD_0000009 ;
                                    owl:someValuesFrom [ owl:intersectionOf ( noes:NOES_0000003
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty co:PMD_0000077 ;
                                                                                owl:someValuesFrom [ owl:intersectionOf ( obo:OBI_0001931
                                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                                            owl:onProperty obo:IAO_0000039 ;
                                                                                                                            owl:hasValue obo:UO_0000106
                                                                                                                          ]
                                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                                            owl:onProperty obo:OBI_0001937 ;
                                                                                                                            owl:someValuesFrom [ rdf:type rdfs:Datatype ;
