                  rdfs:subClassOf noes:NOES_0000179 ;
                  rdfs:label "non-oriented electrical steel"@en ;
                  skos:altLabel "NOES" ,
                                "Non-oriented electrical steel is an electrical steel material which exhibits isotropic magnetic properties in all direction in the sheet plane."@en .


