    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_22977">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33521"/>
        <rdfs:label>cadmium atom</rdfs:label>
    </owl:Class>
    


