AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://w3id.org/pmd/cryo/CRYO_0000044> "I")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000044> "Body centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of a unit cell, i.e., at coordinates (1/2,1/2,1/2)."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000045> (face centered)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000045> "face centered"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://w3id.org/pmd/cryo/CRYO_0000045> "F")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000045> "Face centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of each faces of a unit cell, i.e., at coordinates (1/2,1/2,0), (1/2,0,1/2), and (0,1/2,1/2)."@en)

# Individual: <https://w3id.org/pmd/cryo/CRYO_0000046> (base centered)

AnnotationAssertion(rdfs:comment <https://w3id.org/pmd/cryo/CRYO_0000046> "Add symbol annotation property")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000046> "base centered"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://w3id.org/pmd/cryo/CRYO_0000046> "C")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000046> "Base centered centering type is a centering type, where lattice points are located on the corners of a unit cell, i.e., at coordinates (0,0,0), and one additional lattice point is located at the center of a base of the cell, i.e., at coordinates (1/2,1/2,0)."@en)

