###  https://w3id.org/pmd/noes/NOES_0000070
noes:NOES_0000070 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000003 ;
                  rdfs:label "magnetic field strength"@en ;
                  skos:definition "Magnetic field strength is a process attribute of an aplication of magnetic field process which characterizes the magnitude the external / applied magnetic field."@en ;
                  co:symbol "H" .


###  https://w3id.org/pmd/noes/NOES_0000071
noes:NOES_0000071 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000016 ;
                  rdfs:label "magnetic susceptibility"@en ;
                  skos:definition "Magnetic susceptibility is a disposition of a material which describes how responsive the material is to an applied magnetic field. It is a relation between the induced magnetization M and the magnetic field H."@en ;
                  co:symbol "χ"@en .


###  https://w3id.org/pmd/noes/NOES_0000072
noes:NOES_0000072 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000583 ;
                  rdfs:comment "TODO: refine defintion and maybe move it to PMDco"@en ;
                  rdfs:label "analytical calculation"@en ;
                  skos:definition "Analytical calculation is a computing process which has value specification or measurement datum as a specified output. It applies a closed-form mathematical expression or formula to a set it specified inputs (value specifications) without requiring stochastic sampling, iterative numerical solving, or data-driven training."@en .


###  https://w3id.org/pmd/noes/NOES_0000073
noes:NOES_0000073 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:OBI_0000299 ;
                                    owl:someValuesFrom [ owl:intersectionOf ( obo:IAO_0000109
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty obo:IAO_0000136 ;
                                                                                owl:someValuesFrom noes:NOES_0000008
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:RO_0009006 ;
                                    owl:someValuesFrom noes:NOES_0000042
                                  ] ;
                  rdfs:label "orientation distribution function calculation"@en .


###  https://w3id.org/pmd/noes/NOES_0000074
noes:NOES_0000074 rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000009 ;
                  rdfs:label "crystallographic plane"@en ;
                  skos:definition "Crystallographic plane is a an atomic plane within a crystal lattice defined by its orientation relative to the crystal axes. The orientation is specified by the set of Miller indices (hkl) for a single plane, and {hkl} for a set of equivalent planes."@en ;
                  skos:example "(111) plane, {110} set of planes"@en .


###  https://w3id.org/pmd/noes/NOES_0000075
noes:NOES_0000075 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000501 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000418 ;
                                    owl:allValuesFrom [ owl:intersectionOf ( noes:NOES_0000042
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty obo:RO_0000080 ;
                                                                               owl:allValuesFrom co:PMD_0000663
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ]
                                  ] ;
                  rdfs:label "Euler angles"@en ;
                  skos:definition "In crystallography Euler angles are three angles which describe orientation of a sinlge crystal in respect to the sample's coordinate system. By aligning coordinate system of every crystal in the sample to the sample's coordinate system, anisotropy of material's properties can be investigated."@en .


###  https://w3id.org/pmd/noes/NOES_0000079
noes:NOES_0000079 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000075 ;
                  rdfs:label "Bunge Euler angles"@en ;
                  rdfs:seeAlso "https://mtex-toolbox.github.io/RotationDefinition.html" ;
                  skos:definition "Bunge Euler angles define the Euler angles according to the Bunge notations, which define the three subsequent rotations about fixed axes, namely ZXZ, i.e., the first rotation is around the z axis, second around the x axis and third again around the z."@en .


###  https://w3id.org/pmd/noes/NOES_0000080
noes:NOES_0000080 rdf:type owl:Class ;
                  rdfs:subClassOf co:PMD_0000501 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000219 ;
                                    owl:allValuesFrom [ rdf:type owl:Class ;
                                                        owl:unionOf ( noes:NOES_0000000
                                                                      noes:NOES_0000074
                                                                    )
                                                      ]
                                  ] ;
                  rdfs:comment "TODO: the coordinate of a single atom in the axiom??"@en ;
                  rdfs:label "Miller indices"@en ;
                  skos:definition "In crystallography Miller indices is a notation of lattice planes, directions, and points within a crystal lattice, i.e., in respect to the crystal's coordinate system."@en .


###  https://w3id.org/pmd/noes/NOES_0000081
noes:NOES_0000081 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000080 ;
                  rdfs:comment "TODO: Think what is actually a poinr, does it characterize atom sitting somewhere?"@en ;
                  rdfs:label "point Miller indices"@en ;
                  skos:definition "Point Miller indices define the coordinates of a point within a unit cell of a crystal. Point Miller indices must be given in round brackets separated by commas, e.g., (x, y, z)."@en ;
                  skos:example "(1, 0, 0) point"@en .


###  https://w3id.org/pmd/noes/NOES_0000082
noes:NOES_0000082 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000080 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000219 ;
                                    owl:allValuesFrom noes:NOES_0000074
                                  ] ;
                  rdfs:label "plane Miller indices"@en ;
                  skos:example "(110) plane"@en ,
                               """Plane Miller indices define the reciprocals of the fractional intercepts the plane makes with the crystallographic axes, reduced to the lowest set of integers. 
For example, if a plane crosses [100] axis at 1/h, [010 ] axis at 1/k, and [001] axis at 1/l, then such plane is denoted as (hkl) plane. If a plane is parallel to one of the axes, then the corresponding Miller index is 0.
Plane Miller indices must be written in round brackets, e.g., (hkl)."""@en .


###  https://w3id.org/pmd/noes/NOES_0000083
noes:NOES_0000083 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000080 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000219 ;
                                    owl:allValuesFrom noes:NOES_0000074
                                  ] ;
                  rdfs:comment "TODO: crystallographic plane specification vs vector specification??"@en ;
                  rdfs:label "set of planes Miller indices"@en ;
                  skos:definition "Set of planes Miller indices define set of symmetrically equivalent planes. Set of planes must be written in curly brackets, e.g., {hkl}."@en ,
                                  "{111} set of planes"@en .


###  https://w3id.org/pmd/noes/NOES_0000084
noes:NOES_0000084 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000080 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000219 ;
                                    owl:allValuesFrom noes:NOES_0000000
                                  ] ;
                  rdfs:label "direction Miller indices"@en ;
                  skos:definition "Direction Miller indices define the components of a sinlge vector in the given direction in a crystal's unit cell. Usually, direction Miller indices are reduced to the lowest set of integers. direction Miller indices must be written in square brackets, e.g., [uvw]."@en ;
                  skos:example "[111] direction"@en .


###  https://w3id.org/pmd/noes/NOES_0000085
noes:NOES_0000085 rdf:type owl:Class ;
                  rdfs:subClassOf noes:NOES_0000080 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:IAO_0000219 ;
                                    owl:allValuesFrom noes:NOES_0000000
                                  ] ;
                  rdfs:label "set of directions Miller indices"@en ;
                  skos:definition "Set of directions Miller indices define the components of symmetrically equivalent directions in a crystal's unit cell. Set of directions Miller indices must be written as <uvw>."@en ;
                  skos:example "<110> set of directions"@en .


