                                    owl:onProperty obo:RO_0000057 ;
                                    owl:someValuesFrom noes:NOES_0000183
                                  ] ;
                  rdfs:label "magnetic property analyzing process using Epstein frame"@en ;
                  skos:definition "Magnetic property analyzing process using Epstein frame is a standardized assay which uses Epstein frame to test magnetic properties of soft magnetic materials, where several (how many) strips are stacked."@en .


###  https://w3id.org/pmd/noes/NOES_0000013
noes:NOES_0000013 rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000829
