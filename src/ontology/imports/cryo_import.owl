        <cryo:CRYO_0000019 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</cryo:CRYO_0000019>
        <rdfs:label xml:lang="en">{110}</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000065 -->

