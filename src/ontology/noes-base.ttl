                                 owl:onProperty obo:RO_0000085 ;
                                 owl:someValuesFrom co:PMD_0000592
                               ] ;
               rdfs:label "cutting device"@en ;
               skos:definition "A device designed to cut, slice, divide, or sever objects."@en .


###  https://w3id.org/pmd/co/PMD_0020000
co:PMD_0020000 rdf:type owl:Class ;
               rdfs:subClassOf obo:BFO_0000040 ;
               rdfs:label "phase (thermodynamic)"@en ;
               skos:definition "A thermodynamic phase is portion of matter that is part of a thermodynamic system and has homogeneus thermodynamic properties."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0020003
co:PMD_0020003 rdf:type owl:Class ;
               rdfs:subClassOf obo:BFO_0000030 ;
               rdfs:label "crystal"@en ;
               skos:definition "A crystal is an object that has part some entities that concretize a Bravais lattice."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0020004
co:PMD_0020004 rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( obo:IAO_0000030
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty obo:RO_0000058 ;
                                                            owl:someValuesFrom co:PMD_0025001
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf [ owl:intersectionOf ( obo:IAO_0000030
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty obo:RO_0000058 ;
                                                        owl:someValuesFrom co:PMD_0025001
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:label "composition specification"@en ;
               skos:definition "Composition specification is an information content entity that is conretized by  composition of a portion of matter and has memebers fraction specifications of portions of other matters (but not chemical elements) of which the whole portion of matter consists of (has parts)."@en ;
               skos:example "Nitric acid solution has quality  composition , which concretizes the composition specification .The composition specification has parts fraction specifications of nitric acid, e.g., 4 vol.%, and distilled water. These fraction specifications specify value of pure substances of nitric acid and distilled water, respectively. Furthermore, these fraction specifications are conretized by relational qualities (volume) proportion of nitric acid and (volume) proportion of distilled water."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0020005
co:PMD_0020005 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020131 ;
               rdfs:label "porosity"@en ;
               skos:definition "The porosity is a quality describing the fraction of the materials (enclosing) spatial region occupied by pores."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0020023
co:PMD_0020023 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( co:PMD_0020027
                                                 co:PMD_0020097
                                                 co:PMD_0020100
                                                 co:PMD_0020107
                                                 co:PMD_0020109
                                                 co:PMD_0020110
                                                 co:PMD_0020111
                                               )
                                   ] ;
               rdfs:subClassOf obo:OBI_0001930 ,
                               co:PMD_0020098 ;
               rdfs:label "metallic grain structures"@en ;
               skos:definition "Metallic grain structures are descriptors for the morphology of polycrystalline metallic materials. Polycrystalline metallic materials will typically form their grain structures as one of those categories or a transition or mixture state of those."@en ,
                               "The metallic grain structures is a categorical value specification that specifies value of the  metallic grain structure quality. It describes the morphology of polycrystalline metallic materials. Polycrystalline metallic materials will typically form their grain structures as one of those categories or a transition or mixture state of those."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


