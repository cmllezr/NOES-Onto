AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_22984> "calcium atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_22984> <http://purl.obolibrary.org/obo/CHEBI_33521>)

