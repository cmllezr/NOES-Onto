SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_24061> <http://purl.obolibrary.org/obo/CHEBI_25585>)

# Class: <http://purl.obolibrary.org/obo/CHEBI_24431> (chemical entity)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CHEBI_24431> "A chemical entity is a physical entity of interest in chemistry including molecular entities, parts thereof, and chemical substances.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_24431> "chemical entity")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_24431> <http://purl.obolibrary.org/obo/BFO_0000040>)

