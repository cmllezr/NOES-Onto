# Class: <http://purl.obolibrary.org/obo/UO_0000000> (unit)

AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000000> "\"A unit of measurement is a standardized quantity of a physical quality.\" [Wikipedia:Wikipedia]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000000> "unit")

# Class: <http://purl.obolibrary.org/obo/UO_0000012> (kelvin)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000012> "K")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000012> "\"A thermodynamic temperature unit which is equal to the fraction 1/273.16 of the thermodynamic temperature of the triple point of water.\" [BIPM:BIPM, NIST:NIST]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000012> "kelvin")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000012> <http://purl.obolibrary.org/obo/UO_0000045>)
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000012> <http://purl.obolibrary.org/obo/UO_1000012>)

# Class: <http://purl.obolibrary.org/obo/UO_0000016> (millimeter)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000016> "millimetre")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000016> "mm")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000016> "\"A length unit which is equal to one thousandth of a meter or 10^[-3] m.\" [NIST:NIST]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000016> "millimeter")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000016> <http://purl.obolibrary.org/obo/UO_1000008>)

# Class: <http://purl.obolibrary.org/obo/UO_0000027> (degree Celsius)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000027> "C")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000027> "\"A temperature unit which is equal to one kelvin degree. However, they have their zeros at different points. The centigrade scale has its zero at 273.15 K.\" [NIST:NIST]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000027> "degree Celsius")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000027> <http://purl.obolibrary.org/obo/UO_1000027>)

# Class: <http://purl.obolibrary.org/obo/UO_0000031> (minute)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000031> "min")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000031> "\"A time unit which is equal to 60 seconds.\" [Wikipedia:Wikipedia]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000031> "minute")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000031> <http://purl.obolibrary.org/obo/UO_1000031>)

# Class: <http://purl.obolibrary.org/obo/UO_0000045> (base unit)

AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000045> "\"A unit which is one of a particular measure to which all measures of that type can be related.\" [NIST:NIST]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000045> "base unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000045> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_0000106> (hertz)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000106> "Hz")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000106> "s^1")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000106> "\"A frequency unit which is equal to 1 complete cycle of a recurring phenomenon in 1 second.\" [NIST:NIST]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000106> "hertz")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000106> <http://purl.obolibrary.org/obo/UO_1000106>)

# Class: <http://purl.obolibrary.org/obo/UO_0000163> (mass percentage)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000163> "w/w")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000163> "weight-weight percentage")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000163> "\"A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.\" [Wikipedia:Wikipedia]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000163> "mass percentage")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000163> <http://purl.obolibrary.org/obo/UO_1000163>)

# Class: <http://purl.obolibrary.org/obo/UO_0000190> (ratio unit)

AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000190> "\"A dimensionless unit which denotes an amount or magnitude of one quantity relative to another.\" [Wikipedia:Wikipedia]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000190> "ratio unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000190> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_0000228> (tesla)

AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000228> "T")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000228> "Wb/m2")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0000228> "\"A magnetic flux density unit which is equal to one weber per square meter.\" [WordNet:WordNet]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000228> "tesla")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000228> <http://purl.obolibrary.org/obo/UO_1000228>)

# Class: <http://purl.obolibrary.org/obo/UO_0010006> (ratio)

AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UO_0010006> "\"A dimensionless ratio unit which, given a pair of quantities a and b, for which b is a multiple of a, denotes b by giving the multiplier (coefficient) c for a to result in b.\" [UOB:LKSR]")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0010006> "ratio")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0010006> <http://purl.obolibrary.org/obo/UO_0000190>)

# Class: <http://purl.obolibrary.org/obo/UO_1000008> (meter based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000008> "meter based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000008> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_1000012> (kelvin based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000012> "kelvin based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000012> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_1000027> (degree Celsius based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000027> "degree Celsius based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000027> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_1000031> (minute based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000031> "minute based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000031> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_1000106> (hertz based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000106> "hertz based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000106> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_1000163> (mass percentage based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000163> "mass percentage based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000163> <http://purl.obolibrary.org/obo/UO_0000000>)
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000163> <http://purl.obolibrary.org/obo/UO_0000190>)

# Class: <http://purl.obolibrary.org/obo/UO_1000228> (tesla based unit)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_1000228> "tesla based unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_1000228> <http://purl.obolibrary.org/obo/UO_0000000>)



