    <!-- https://w3id.org/pmd/noes/NOES_0000030 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/noes/NOES_0000030">
        <rdfs:label xml:lang="en">normal direction (ND)</rdfs:label>
