                                    owl:onProperty obo:BFO_0000051 ;
                                    owl:someValuesFrom co:PMD_0020050
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty obo:BFO_0000051 ;
                                    owl:someValuesFrom [ owl:intersectionOf ( co:PMD_0000857
                                                                              [ rdf:type owl:Restriction ;
