AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_25585> "nonmetal atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_25585> <http://purl.obolibrary.org/obo/CHEBI_33250>)

# Class: <http://purl.obolibrary.org/obo/CHEBI_25805> (oxygen atom)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_25805> "oxygen atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_25805> <http://purl.obolibrary.org/obo/CHEBI_25585>)
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_25805> <http://purl.obolibrary.org/obo/CHEBI_33303>)

# Class: <http://purl.obolibrary.org/obo/CHEBI_26216> (potassium atom)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_26216> "potassium atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_26216> <http://purl.obolibrary.org/obo/CHEBI_33521>)

# Class: <http://purl.obolibrary.org/obo/CHEBI_26708> (sodium atom)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CHEBI_26708> "sodium atom")
SubClassOf(<http://purl.obolibrary.org/obo/CHEBI_26708> <http://purl.obolibrary.org/obo/CHEBI_33521>)

