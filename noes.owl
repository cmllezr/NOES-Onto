            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A person or organization that has a manufacturer role.</obo:IAO_0000115>
        <rdfs:label>manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001930 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001930">
